FROM node:18-alpine

WORKDIR /app

# Copy package.json and install dependencies
COPY package.json package-lock.json ./
RUN npm ci --only=production

# Copy the MCP server source
COPY src/mcp-servers ./src/mcp-servers
COPY dist/mcp-servers ./dist/mcp-servers 2>/dev/null || true

# Create data directory for Obsidian vault
RUN mkdir -p /data/vault

# Expose the MCP server port
EXPOSE 3000

# Set health check
HEALTHCHECK --interval=10s --timeout=5s --retries=5 \
  CMD node -e "require('http').get('http://localhost:3000/health', (r) => {if (r.statusCode !== 200) throw new Error(r.statusCode)})" || exit 1

# Start the MCP server
CMD ["node", "dist/mcp-servers/obsidian-notes-server.js"]
