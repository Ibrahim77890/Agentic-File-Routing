{
  "name": "agentic-file-routing",
  "version": "0.2.0",
  "description": "AFR: File-system routed hierarchical agent runtime",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "create-afr-agent": "./bin/create-afr-agent.mjs",
    "afr": "./bin/afr.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "if exist dist rmdir /s /q dist",
    "dev": "node dist/cli/afr-dev.js",
    "test": "node --test dist/tests/**/*.test.js",
    "test:watch": "tsc -p tsconfig.json --watch"
  },
  "keywords": [
    "agents",
    "llm",
    "routing",
    "orchestration",
    "afr"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.3",
    "dotenv": "^16.4.5",
    "typescript": "^5.8.2"
  }
}